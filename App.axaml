<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DicomViewer.App"
             xmlns:local="using:DicomViewer"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <FontFamily x:Key="Codicon">avares://DicomViewer/Assets/Fonts/codicon.ttf#codicon</FontFamily>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DicomViewer/Styles/DicomViewerStyles.axaml"/>
    </Application.Styles>

</Application>
