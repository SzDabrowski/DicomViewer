<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Toolbar & Tools -->
    <sys:String x:Key="Open">Open</sys:String>
    <sys:String x:Key="OpenFiles">Open File(s)...</sys:String>
    <sys:String x:Key="OpenDirectory">Open Directory...</sys:String>
    <sys:String x:Key="Arrow">Arrow</sys:String>
    <sys:String x:Key="TextLabel">Text Label</sys:String>
    <sys:String x:Key="FreehandDraw">Freehand Draw</sys:String>
    <sys:String x:Key="Annotate">Annotate</sys:String>
    <sys:String x:Key="Rectangle">Rectangle</sys:String>
    <sys:String x:Key="Ellipse">Ellipse</sys:String>
    <sys:String x:Key="Line">Line</sys:String>
    <sys:String x:Key="Draw">Draw</sys:String>
    <sys:String x:Key="Fit">Fit</sys:String>
    <sys:String x:Key="Reset">Reset</sys:String>
    <sys:String x:Key="Settings">Settings</sys:String>
    <sys:String x:Key="Presets">Presets</sys:String>

    <!-- Tooltips -->
    <sys:String x:Key="Tip_OpenFileOrDir">Open File or Directory (Ctrl+O)</sys:String>
    <sys:String x:Key="Tip_PanZoom">Pan / Zoom</sys:String>
    <sys:String x:Key="Tip_WindowLevel">Window/Level</sys:String>
    <sys:String x:Key="Tip_AnnotateTools">Annotate Tools</sys:String>
    <sys:String x:Key="Tip_DrawShapes">Draw Shapes</sys:String>
    <sys:String x:Key="Tip_AnnotationColor">Annotation Color</sys:String>
    <sys:String x:Key="Tip_RotateCCW">Rotate Counter-Clockwise</sys:String>
    <sys:String x:Key="Tip_RotateCW">Rotate Clockwise</sys:String>
    <sys:String x:Key="Tip_FlipH">Flip Horizontal</sys:String>
    <sys:String x:Key="Tip_FlipV">Flip Vertical</sys:String>
    <sys:String x:Key="Tip_InvertColors">Invert Colors (I)</sys:String>
    <sys:String x:Key="Tip_WindowPresets">Window Presets</sys:String>
    <sys:String x:Key="Tip_LogViewer">Log Viewer (Ctrl+L)</sys:String>
    <sys:String x:Key="Tip_ZoomOut">Zoom Out (-)</sys:String>
    <sys:String x:Key="Tip_ZoomIn">Zoom In (+)</sys:String>
    <sys:String x:Key="Tip_FitToWindow">Fit to Window (F)</sys:String>
    <sys:String x:Key="Tip_ResetView">Reset View (R)</sys:String>
    <sys:String x:Key="Tip_ToggleOverlay">Toggle Overlay</sys:String>
    <sys:String x:Key="Tip_ToggleFilmstrip">Toggle Filmstrip</sys:String>
    <sys:String x:Key="Tip_ToggleFilePanel">Toggle File Panel</sys:String>
    <sys:String x:Key="Tip_Minimise">Minimise</sys:String>
    <sys:String x:Key="Tip_MaximiseRestore">Maximise / Restore</sys:String>
    <sys:String x:Key="Tip_Close">Close</sys:String>
    <sys:String x:Key="Tip_FirstFrame">First Frame</sys:String>
    <sys:String x:Key="Tip_PreviousFrame">Previous Frame</sys:String>
    <sys:String x:Key="Tip_PlayPause">Play / Pause (Space)</sys:String>
    <sys:String x:Key="Tip_NextFrame">Next Frame</sys:String>
    <sys:String x:Key="Tip_LastFrame">Last Frame</sys:String>
    <sys:String x:Key="Tip_LoopPlayback">Loop Playback</sys:String>
    <sys:String x:Key="Tip_CopyErrorDetails">Copy error details</sys:String>
    <sys:String x:Key="Tip_Dismiss">Dismiss</sys:String>
    <sys:String x:Key="Tip_CollapseFilmstrip">Collapse Filmstrip</sys:String>
    <sys:String x:Key="Tip_ExpandFilmstrip">Expand Filmstrip</sys:String>
    <sys:String x:Key="Tip_HideFilePanel">Hide File Panel</sys:String>
    <sys:String x:Key="Tip_ShowFilePanel">Show File Panel</sys:String>

    <!-- Colors -->
    <sys:String x:Key="Yellow">Yellow</sys:String>
    <sys:String x:Key="Cyan">Cyan</sys:String>
    <sys:String x:Key="Red">Red</sys:String>
    <sys:String x:Key="Green">Green</sys:String>
    <sys:String x:Key="Blue">Blue</sys:String>
    <sys:String x:Key="Magenta">Magenta</sys:String>
    <sys:String x:Key="Orange">Orange</sys:String>
    <sys:String x:Key="White">White</sys:String>

    <!-- Window/Level Presets -->
    <sys:String x:Key="Brain">Brain</sys:String>
    <sys:String x:Key="Lung">Lung</sys:String>
    <sys:String x:Key="Bone">Bone</sys:String>
    <sys:String x:Key="Abdomen">Abdomen</sys:String>
    <sys:String x:Key="Mediastinum">Mediastinum</sys:String>
    <sys:String x:Key="Liver">Liver</sys:String>
    <sys:String x:Key="SoftTissue">Soft Tissue</sys:String>
