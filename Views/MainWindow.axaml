<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DicomViewer.ViewModels"
        xmlns:ctrl="using:DicomViewer.Controls"
        xmlns:conv="using:DicomViewer.Converters"
        xmlns:svc="using:DicomViewer.Services"
        xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
        x:Class="DicomViewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DICOM Viewer"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="BorderOnly"
        Width="1440" Height="900"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True">

	<Window.Resources>
		<conv:BoolToOpacityConverter x:Key="BoolToOpacity"/>
		<conv:BoolToWidthConverter x:Key="BoolToWidth" TrueWidth="260" FalseWidth="0"/>
		<conv:ToolToActiveConverter x:Key="ToolToActive"/>
		<conv:BoolToColorConverter x:Key="BoolToColor"/>
		<conv:BoolToAccentConverter x:Key="BoolToAccent"/>
		<conv:BoolToWhiteConverter x:Key="BoolToWhite"/>
		<conv:ProgressToWidthConverter x:Key="ProgressToWidth"/>
		<conv:BoolToTooltipDelayConverter x:Key="BoolToTooltipDelay"/>
		<conv:LogLevelToColorConverter x:Key="LogLevelToColor"/>
		<conv:SeverityToBackgroundConverter x:Key="SeverityToBackground"/>
		<conv:SeverityToBorderConverter x:Key="SeverityToBorder"/>
		<conv:SeverityToIconColorConverter x:Key="SeverityToIconColor"/>
		<conv:SeverityToIconConverter x:Key="SeverityToIcon"/>
		<conv:HasDetailsConverter x:Key="HasDetails"/>
	</Window.Resources>

	<Window.Styles>
		<Style Selector="Button.WinBtn">
			<Setter Property="Width" Value="46"/>
			<Setter Property="Height" Value="42"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="0"/>
			<Setter Property="VerticalAlignment" Value="Stretch"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
						<ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"/>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="Button.WinBtn:pointerover /template/ Border">
			<Setter Property="Background" Value="#2A2A3A"/>
		</Style>
		<Style Selector="Button.WinBtn:pointerover TextBlock">
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector="Button.WinBtnClose:pointerover /template/ Border">
			<Setter Property="Background" Value="#C42B1C"/>
		</Style>
		<Style Selector="Button.WinBtnClose:pointerover TextBlock">
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector=":is(Button)">
			<Setter Property="ToolTip.ShowDelay" Value="{Binding ShowTooltips, Converter={StaticResource BoolToTooltipDelay}}"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="42,Auto,*,Auto,Auto,Auto,Auto">

		<!-- ROW 0: TOOLBAR + CUSTOM TITLE BAR -->
		<Border Grid.Row="0" Background="#111118" BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
                Padding="8,0,0,0" ClipToBounds="True">
			<Grid ColumnDefinitions="Auto,*,Auto">

				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
					<Button Classes="ToolbarBtn" ToolTip.Tip="{Binding Loc[Tip_OpenFileOrDir]}" UseLayoutRounding="True">
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedLeft">
								<MenuItem Command="{Binding OpenFileCommand}">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<iconPacks:PackIconCodicons Kind="File" Width="14" Height="14" VerticalAlignment="Center" Foreground="#4A9EFF"/>
											<TextBlock Text="{Binding Loc[OpenFiles]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding OpenDirectoryCommand}">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<iconPacks:PackIconCodicons Kind="FolderOpened" Width="14" Height="14" VerticalAlignment="Center" Foreground="#4A9EFF"/>
											<TextBlock Text="{Binding Loc[OpenDirectory]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
							</MenuFlyout>
						</Button.Flyout>
						<StackPanel Orientation="Horizontal" Spacing="5" UseLayoutRounding="True">
							<iconPacks:PackIconCodicons Kind="FolderOpened" Width="14" Height="14" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Open]}" FontSize="12" VerticalAlignment="Center" Height="16" Padding="0" LineHeight="16"/>
							<iconPacks:PackIconCodicons Kind="ChevronDown" Width="9" Height="9" VerticalAlignment="Center" Margin="0,1,0,0"/>
						</StackPanel>
					</Button>
					<Rectangle Width="1" Height="22" Fill="#2A2A3A" Margin="4,0"/>

					<Button Classes="IconBtn"
                            Command="{Binding SelectToolCommand}" CommandParameter="Pan"
                            Classes.Active="{Binding ActiveTool, Converter={StaticResource ToolToActive}, ConverterParameter=Pan}"
                            ToolTip.Tip="{Binding Loc[Tip_PanZoom]}">
						<iconPacks:PackIconCodicons Kind="Move" Width="16" Height="16" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn"
                            Command="{Binding SelectToolCommand}" CommandParameter="WindowLevel"
                            Classes.Active="{Binding ActiveTool, Converter={StaticResource ToolToActive}, ConverterParameter=WindowLevel}"
                            ToolTip.Tip="{Binding Loc[Tip_WindowLevel]}">
						<iconPacks:PackIconCodicons Kind="Target" Width="16" Height="16" VerticalAlignment="Center"/>
					</Button>
					<!-- Annotate tools flyout -->
					<Button Classes="ToolbarBtn" ToolTip.Tip="{Binding Loc[Tip_AnnotateTools]}" UseLayoutRounding="True">
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedLeft">
								<MenuItem Command="{Binding SelectToolCommand}" CommandParameter="Arrow">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEA9C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#FFD700"/>
											<TextBlock Text="{Binding Loc[Arrow]}" VerticalAlignment="Center"/>
											<TextBlock Text="A" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SelectToolCommand}" CommandParameter="TextLabel">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEA6F;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#00E5FF"/>
											<TextBlock Text="{Binding Loc[TextLabel]}" VerticalAlignment="Center"/>
											<TextBlock Text="T" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SelectToolCommand}" CommandParameter="Freehand">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5B;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#44FF44"/>
											<TextBlock Text="{Binding Loc[FreehandDraw]}" VerticalAlignment="Center"/>
											<TextBlock Text="D" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
							</MenuFlyout>
						</Button.Flyout>
						<StackPanel Orientation="Horizontal" Spacing="4" UseLayoutRounding="True">
							<iconPacks:PackIconCodicons Kind="Edit" Width="14" Height="14" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Annotate]}" FontSize="11" VerticalAlignment="Center" Height="16" Padding="0" LineHeight="16"/>
							<iconPacks:PackIconCodicons Kind="ChevronDown" Width="9" Height="9" VerticalAlignment="Center" Margin="0,1,0,0"/>
						</StackPanel>
					</Button>
					<!-- Draw shapes flyout -->
					<Button Classes="ToolbarBtn" ToolTip.Tip="{Binding Loc[Tip_DrawShapes]}" UseLayoutRounding="True">
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedLeft">
								<MenuItem Command="{Binding SelectToolCommand}" CommandParameter="DrawRect">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB01;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#FFD700"/>
											<TextBlock Text="{Binding Loc[Rectangle]}" VerticalAlignment="Center"/>
											<TextBlock Text="R" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SelectToolCommand}" CommandParameter="DrawEllipse">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB10;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#00E5FF"/>
											<TextBlock Text="{Binding Loc[Ellipse]}" VerticalAlignment="Center"/>
											<TextBlock Text="O" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SelectToolCommand}" CommandParameter="DrawLine">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEA61;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#44FF44"/>
											<TextBlock Text="{Binding Loc[Line]}" VerticalAlignment="Center"/>
											<TextBlock Text="L" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
							</MenuFlyout>
						</Button.Flyout>
						<StackPanel Orientation="Horizontal" Spacing="4" UseLayoutRounding="True">
							<iconPacks:PackIconCodicons Kind="SymbolMisc" Width="14" Height="14" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Draw]}" FontSize="11" VerticalAlignment="Center" Height="16" Padding="0" LineHeight="16"/>
							<iconPacks:PackIconCodicons Kind="ChevronDown" Width="9" Height="9" VerticalAlignment="Center" Margin="0,1,0,0"/>
						</StackPanel>
					</Button>
					<!-- Annotation color picker -->
					<Button Classes="ToolbarBtn" ToolTip.Tip="{Binding Loc[Tip_AnnotationColor]}" UseLayoutRounding="True">
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedLeft">
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="0">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#FFD700"/>
											<TextBlock Text="{Binding Loc[Yellow]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="1">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#00E5FF"/>
											<TextBlock Text="{Binding Loc[Cyan]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="2">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#FF4444"/>
											<TextBlock Text="{Binding Loc[Red]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="3">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#44FF44"/>
											<TextBlock Text="{Binding Loc[Green]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="4">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#4488FF"/>
											<TextBlock Text="{Binding Loc[Blue]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="5">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#FF44FF"/>
											<TextBlock Text="{Binding Loc[Magenta]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="6">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#FF8800"/>
											<TextBlock Text="{Binding Loc[Orange]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding SetAnnotationColorCommand}" CommandParameter="7">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Width="14" Height="14" CornerRadius="7" Background="#FFFFFF"/>
											<TextBlock Text="{Binding Loc[White]}" VerticalAlignment="Center"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
							</MenuFlyout>
						</Button.Flyout>
						<StackPanel Orientation="Horizontal" Spacing="4" UseLayoutRounding="True">
							<iconPacks:PackIconCodicons Kind="SymbolColor" Width="14" Height="14" VerticalAlignment="Center"/>
							<iconPacks:PackIconCodicons Kind="ChevronDown" Width="9" Height="9" VerticalAlignment="Center" Margin="0,1,0,0"/>
						</StackPanel>
					</Button>
					<Rectangle Width="1" Height="22" Fill="#2A2A3A" Margin="4,0"/>

					<Button Classes="IconBtn" Command="{Binding RotateCCWCommand}" ToolTip.Tip="{Binding Loc[Tip_RotateCCW]}">
						<iconPacks:PackIconCodicons Kind="Discard" Width="16" Height="16" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn" Command="{Binding RotateCWCommand}" ToolTip.Tip="{Binding Loc[Tip_RotateCW]}">
						<iconPacks:PackIconCodicons Kind="Redo" Width="16" Height="16" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn" Command="{Binding FlipHCommand}" ToolTip.Tip="{Binding Loc[Tip_FlipH]}">
						<iconPacks:PackIconCodicons Kind="ArrowBoth" Width="16" Height="16" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn" Command="{Binding FlipVCommand}" ToolTip.Tip="{Binding Loc[Tip_FlipV]}">
						<iconPacks:PackIconCodicons Kind="Mirror" Width="16" Height="16" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn" Command="{Binding ToggleInvertCommand}"
                            Classes.Active="{Binding InvertColors}"
                            ToolTip.Tip="{Binding Loc[Tip_InvertColors]}">
						<iconPacks:PackIconCodicons Kind="CircleSlash" Width="14" Height="14" VerticalAlignment="Center"/>
					</Button>
					<Rectangle Width="1" Height="22" Fill="#2A2A3A" Margin="4,0"/>

					<Button Classes="ToolbarBtn" ToolTip.Tip="{Binding Loc[Tip_WindowPresets]}" UseLayoutRounding="True">
						<Button.Flyout>
							<MenuFlyout Placement="BottomEdgeAlignedLeft">
								<MenuItem Command="{Binding ApplyWindowPresetCommand}" CommandParameter="Brain">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#C084FC"/>
											<TextBlock Text="{Binding Loc[Brain]}" VerticalAlignment="Center"/>
											<TextBlock Text="C:40 W:80" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding ApplyWindowPresetCommand}" CommandParameter="Lung">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#60A5FA"/>
											<TextBlock Text="{Binding Loc[Lung]}" VerticalAlignment="Center"/>
											<TextBlock Text="C:-600 W:1500" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding ApplyWindowPresetCommand}" CommandParameter="Bone">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#F9F9F9"/>
											<TextBlock Text="{Binding Loc[Bone]}" VerticalAlignment="Center"/>
											<TextBlock Text="C:400 W:1800" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding ApplyWindowPresetCommand}" CommandParameter="Abdomen">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#FB923C"/>
											<TextBlock Text="{Binding Loc[Abdomen]}" VerticalAlignment="Center"/>
											<TextBlock Text="C:60 W:400" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding ApplyWindowPresetCommand}" CommandParameter="Mediastinum">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#F87171"/>
											<TextBlock Text="{Binding Loc[Mediastinum]}" VerticalAlignment="Center"/>
											<TextBlock Text="C:40 W:400" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<MenuItem Command="{Binding ApplyWindowPresetCommand}" CommandParameter="Liver">
									<MenuItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#xEB5C;" FontFamily="{StaticResource Codicon}" FontSize="14" VerticalAlignment="Center" Foreground="#A3E635"/>
											<TextBlock Text="{Binding Loc[Liver]}" VerticalAlignment="Center"/>
											<TextBlock Text="C:60 W:150" Foreground="#555570" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
							</MenuFlyout>
						</Button.Flyout>
						<StackPanel Orientation="Horizontal" Spacing="4" UseLayoutRounding="True">
							<TextBlock Text="{Binding Loc[Presets]}" FontSize="11" VerticalAlignment="Center" Height="16" Padding="0" LineHeight="16"/>
							<iconPacks:PackIconCodicons Kind="ChevronDown" Width="9" Height="9" VerticalAlignment="Center" Margin="0,1,0,0"/>
						</StackPanel>
					</Button>
					<Rectangle Width="1" Height="22" Fill="#2A2A3A" Margin="4,0"/>
					<Button Classes="IconBtn" ToolTip.Tip="{Binding Loc[Tip_LogViewer]}"
					        x:Name="LogViewerBtn">
						<iconPacks:PackIconCodicons Kind="Output" Width="14" Height="14" VerticalAlignment="Center"/>
					</Button>
					<Rectangle Width="1" Height="22" Fill="#2A2A3A" Margin="4,0"/>
					<Button Classes="ToolbarBtn" ToolTip.Tip="{Binding Loc[Settings]}" UseLayoutRounding="True"
					        x:Name="SettingsBtn">
						<StackPanel Orientation="Horizontal" Spacing="5" UseLayoutRounding="True">
							<iconPacks:PackIconCodicons Kind="Gear" Width="14" Height="14" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Settings]}" FontSize="11" VerticalAlignment="Center" Height="16" Padding="0" LineHeight="16"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<Border Grid.Column="1" x:Name="TitleBarDragArea" IsHitTestVisible="True">
					<Grid>
						<TextBlock Text="{Binding ActiveFileInfo}" Foreground="#8888A8" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Margin="12,0"
                                   IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNotNull}}"/>
						<TextBlock Text="{Binding Loc[DicomViewer]}" Foreground="#444460" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNull}}"/>
					</Grid>
				</Border>

				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
					<StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="0,0,2,0">
						<Button Classes="IconBtn" Command="{Binding ZoomOutCommand}" ToolTip.Tip="{Binding Loc[Tip_ZoomOut]}">
							<iconPacks:PackIconCodicons Kind="ZoomOut" Width="14" Height="14" VerticalAlignment="Center"/>
						</Button>
						<Border Background="#1C1C28" CornerRadius="4" Padding="8,4" MinWidth="58" VerticalAlignment="Center">
							<TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" Foreground="#8888A8"
                                       FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<Button Classes="IconBtn" Command="{Binding ZoomInCommand}" ToolTip.Tip="{Binding Loc[Tip_ZoomIn]}">
							<iconPacks:PackIconCodicons Kind="ZoomIn" Width="14" Height="14" VerticalAlignment="Center"/>
						</Button>
						<Button Classes="ToolbarBtn" Command="{Binding FitToWindowCommand}" ToolTip.Tip="{Binding Loc[Tip_FitToWindow]}" UseLayoutRounding="True">
							<TextBlock Text="{Binding Loc[Fit]}" FontSize="12" VerticalAlignment="Center" Height="16" LineHeight="16"/>
						</Button>
						<Button Classes="ToolbarBtn" Command="{Binding ResetViewCommand}" ToolTip.Tip="{Binding Loc[Tip_ResetView]}" UseLayoutRounding="True">
							<TextBlock Text="{Binding Loc[Reset]}" FontSize="12" VerticalAlignment="Center" Height="16" LineHeight="16"/>
						</Button>
						<Rectangle Width="1" Height="22" Fill="#2A2A3A" Margin="4,0"/>
						<Button Classes="IconBtn" Command="{Binding ToggleOverlayCommand}"
                            Classes.Active="{Binding ShowOverlay}"
                            ToolTip.Tip="{Binding Loc[Tip_ToggleOverlay]}">
							<iconPacks:PackIconCodicons Kind="Info" Width="14" Height="14" VerticalAlignment="Center"/>
						</Button>
						<Button Classes="IconBtn" Command="{Binding ToggleMiniFramesCommand}"
                            Classes.Active="{Binding ShowMiniFrames}"
                            ToolTip.Tip="{Binding Loc[Tip_ToggleFilmstrip]}">
							<iconPacks:PackIconCodicons Kind="ListFlat" Width="14" Height="14" VerticalAlignment="Center"/>
						</Button>
						<Button Classes="IconBtn" Command="{Binding ToggleRightPanelCommand}"
                            Classes.Active="{Binding IsRightPanelVisible}"
                            ToolTip.Tip="{Binding Loc[Tip_ToggleFilePanel]}">
							<iconPacks:PackIconCodicons Kind="Menu" Width="14" Height="14" VerticalAlignment="Center"/>
						</Button>
					</StackPanel>
					<Rectangle Width="1" Fill="#2A2A3A" VerticalAlignment="Stretch" Margin="2,0"/>
					<Button x:Name="BtnMinimise" Classes="WinBtn" ToolTip.Tip="{Binding Loc[Tip_Minimise]}">
						<iconPacks:PackIconCodicons Kind="ChromeMinimize" Width="14" Height="14" Foreground="#8888A8"/>
					</Button>
					<Button x:Name="BtnMaximise" Classes="WinBtn" ToolTip.Tip="{Binding Loc[Tip_MaximiseRestore]}">
						<iconPacks:PackIconCodicons x:Name="MaximiseIcon" Kind="ChromeMaximize" Width="14" Height="14" Foreground="#8888A8"/>
					</Button>
					<Button x:Name="BtnClose" Classes="WinBtn WinBtnClose" ToolTip.Tip="{Binding Loc[Tip_Close]}">
						<iconPacks:PackIconCodicons Kind="ChromeClose" Width="14" Height="14" Foreground="#8888A8"/>
					</Button>
				</StackPanel>

			</Grid>
		</Border>

		<!-- ROW 1: FILE TABS -->
		<Border Grid.Row="1" Background="#0D0D14" BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
                IsVisible="{Binding HasMultipleFiles}">
			<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
				<ItemsControl ItemsSource="{Binding OpenFiles}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Margin="4,0,0,0"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:DicomFileViewModel">
							<Border Margin="2,4,0,0" CornerRadius="6,6,0,0" Padding="10,5,6,5"
                                    Cursor="Hand" BorderThickness="1,1,1,0" BorderBrush="#2A2A3A"
                                    Background="{Binding IsActive, Converter={StaticResource BoolToAccent}}"
                                    PointerPressed="OnTabPointerPressed">
								<Border.Styles>
									<Style Selector="Border:pointerover">
										<Setter Property="Background" Value="#1C1C30"/>
									</Style>
								</Border.Styles>
								<StackPanel Orientation="Horizontal" Spacing="6">
									<TextBlock Text="{Binding Modality}" Foreground="#4A9EFF"
                                               FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding FileName}" Foreground="#C8C8D8"
                                               FontSize="11" MaxWidth="140" TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
									<TextBlock Text="{Binding TotalFrames, StringFormat={}({0})}"
                                               Foreground="#555570" FontSize="10" VerticalAlignment="Center"/>
									<Button Classes="DangerBtn"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseFileCommand}"
                                            CommandParameter="{Binding}"
                                            Width="16" Height="16" Padding="0" VerticalAlignment="Center">
										<iconPacks:PackIconCodicons Kind="Close" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Button>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</Border>

		<!-- ROW 2: CANVAS + RIGHT PANEL -->
		<Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">

			<Grid Grid.Column="0">
				<ctrl:DicomCanvas x:Name="MainCanvas"
                                  WindowCenter="{Binding WindowCenter}"
                                  WindowWidth="{Binding WindowWidth}"
                                  IsInverted="{Binding InvertColors}"
                                  ZoomLevel="{Binding ZoomLevel}"
                                  PanX="{Binding PanX}"
                                  PanY="{Binding PanY}"
                                  Rotation="{Binding Rotation}"
                                  IsFlippedH="{Binding IsFlippedH}"
                                  IsFlippedV="{Binding IsFlippedV}"
                                  ActiveTool="{Binding ActiveTool}"
                                  ShowAnnotations="{Binding ShowAnnotations}"
                                  AnnotationColorIndex="{Binding AnnotationColorIndex}"
                                  AnnotationStrokeWidth="{Binding AnnotationStrokeWidth}"
                                  AnnotationFontSize="{Binding AnnotationFontSize}"/>

				<Grid IsVisible="{Binding ShowOverlay}" IsHitTestVisible="False" Margin="10">
					<StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="2"
                                IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNotNull}}">
						<TextBlock Text="{Binding ActiveFile.PatientName}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
						<TextBlock Text="{Binding ActiveFile.PatientId, StringFormat={}ID: {0}}" Foreground="#DDDDDD" FontSize="10"/>
						<TextBlock Text="{Binding ActiveFile.StudyDate, StringFormat={}Date: {0}}" Foreground="#DDDDDD" FontSize="10"/>
					</StackPanel>
					<StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="2"
                                IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNotNull}}">
						<TextBlock Text="{Binding ActiveFile.Modality}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
						<TextBlock Text="{Binding WindowCenter, StringFormat={}WC: {0:F0}}" Foreground="#DDDDDD" FontSize="10" HorizontalAlignment="Right"/>
						<TextBlock Text="{Binding WindowWidth, StringFormat={}WW: {0:F0}}" Foreground="#DDDDDD" FontSize="10" HorizontalAlignment="Right"/>
						<TextBlock Text="{Binding ZoomLevel, StringFormat={}Zoom: {0:P0}}" Foreground="#DDDDDD" FontSize="10" HorizontalAlignment="Right"/>
					</StackPanel>
					<StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Spacing="2"
                                IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNotNull}}">
						<TextBlock Text="{Binding ActiveFile.SeriesDescription}" Foreground="#DDDDDD" FontSize="10"/>
						<TextBlock Text="{Binding ActiveFile.FileName}" Foreground="#AAAAAA" FontSize="10"/>
					</StackPanel>
					<StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="2"
                                IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNotNull}}">
						<TextBlock HorizontalAlignment="Right" Foreground="#DDDDDD" FontSize="10">
							<Run Text="{Binding Loc[Frame]}"/><Run Text=" "/>
							<Run Text="{Binding CurrentFrameDisplay}"/>
							<Run Text=" / "/>
							<Run Text="{Binding TotalFrames}"/>
						</TextBlock>
						<TextBlock Text="{Binding ActiveTool, StringFormat={}Tool: {0}}" Foreground="#AAAAAA" FontSize="10" HorizontalAlignment="Right"/>
					</StackPanel>
				</Grid>

				<Border IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNull}}" IsHitTestVisible="False">
					<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
						<iconPacks:PackIconCodicons Kind="FolderOpened" Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.3"/>
						<TextBlock Text="{Binding Loc[NoFileLoaded]}" Foreground="#555570" FontSize="16"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
						<TextBlock Text="{Binding Loc[OpenOrDragDrop]}" Foreground="#444460"
                                   FontSize="12" HorizontalAlignment="Center"/>
						<TextBlock Text="{Binding Loc[CtrlODragDrop]}" Foreground="#333350"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
					</StackPanel>
				</Border>

				<Border IsVisible="{Binding IsLoadingFile}" Background="#CC000000"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
					<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
						<Border Width="56" Height="56" HorizontalAlignment="Center" CornerRadius="28"
                                BorderBrush="#4A9EFF" BorderThickness="4"/>
						<TextBlock Text="{Binding Loc[LoadingDicomFile]}" Foreground="#E8E8F0" FontSize="16"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
						<TextBlock Text="{Binding StatusMessage}" Foreground="#8888A8" FontSize="12"
                                   HorizontalAlignment="Center" MaxWidth="320" TextWrapping="Wrap" TextAlignment="Center"/>
						<Border Width="280" Height="4" CornerRadius="2" Background="#2A2A3A">
							<Border HorizontalAlignment="Left" Height="4" CornerRadius="2" Background="#4A9EFF"
                                    Width="{Binding LoadingProgress, Converter={StaticResource ProgressToWidth}}"/>
						</Border>
						<TextBlock Text="{Binding LoadingProgress, StringFormat={}{0:F0}%}" Foreground="#4A9EFF"
                                   FontSize="11" FontWeight="Medium" HorizontalAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- NOTIFICATION BAR -->
				<ItemsControl ItemsSource="{Binding Notifications}"
				              HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
				              Margin="16,0,16,12">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Spacing="6"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:NotificationViewModel">
							<Border Background="{Binding Severity, Converter={StaticResource SeverityToBackground}}"
							        BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBorder}}"
							        BorderThickness="1" CornerRadius="8" Padding="12,8"
							        BoxShadow="0 4 16 #40000000">
								<Grid ColumnDefinitions="Auto,*,Auto,Auto">
									<!-- Icon -->
									<iconPacks:PackIconCodicons Grid.Column="0"
									                            Kind="{Binding Severity, Converter={StaticResource SeverityToIcon}}"
									                            Width="16" Height="16"
									                            Foreground="{Binding Severity, Converter={StaticResource SeverityToIconColor}}"
									                            VerticalAlignment="Center" Margin="0,0,10,0"/>

									<!-- Message + Label -->
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="{Binding SeverityLabel}" FontSize="9" FontWeight="Bold"
											           Foreground="{Binding Severity, Converter={StaticResource SeverityToIconColor}}"
											           VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Message}" Foreground="#E8E8F0" FontSize="12"
											           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
										</StackPanel>
										<TextBlock Text="{Binding Details}" Foreground="#8888A8" FontSize="10"
										           MaxLines="2" TextTrimming="CharacterEllipsis"
										           IsVisible="{Binding Details, Converter={StaticResource HasDetails}}"/>
									</StackPanel>

									<!-- Copy button -->
									<Button Grid.Column="2" Classes="IconBtn"
									        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CopyNotificationDetailsCommand}"
									        CommandParameter="{Binding}"
									        ToolTip.Tip="{Binding Loc[Tip_CopyErrorDetails]}"
									        IsVisible="{Binding Details, Converter={StaticResource HasDetails}}"
									        VerticalAlignment="Center" Margin="6,0">
										<iconPacks:PackIconCodicons Kind="Copy" Width="13" Height="13"/>
									</Button>

									<!-- Dismiss button -->
									<Button Grid.Column="3" Classes="IconBtn"
									        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DismissNotificationCommand}"
									        CommandParameter="{Binding}"
									        ToolTip.Tip="{Binding Loc[Tip_Dismiss]}"
									        VerticalAlignment="Center">
										<iconPacks:PackIconCodicons Kind="Close" Width="13" Height="13"/>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<Border Name="DropOverlay" Background="#CC000000" IsVisible="False" IsHitTestVisible="False">
					<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
						<iconPacks:PackIconCodicons Kind="FolderOpened" Width="80" Height="80" HorizontalAlignment="Center" Opacity="0.8"/>
						<TextBlock Text="{Binding Loc[DropFilesHere]}" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
					</StackPanel>
				</Border>
			</Grid>

			<GridSplitter Grid.Column="1" Width="6" Background="#16161F"
			             ResizeDirection="Columns"
			             IsVisible="{Binding IsRightPanelVisible}"/>

			<Border Grid.Column="2"
                    Width="260" MinWidth="150" MaxWidth="400"
                    IsVisible="{Binding IsRightPanelVisible}"
                    Background="#16161F" BorderBrush="#2A2A3A" BorderThickness="0,0,0,0"
                    ClipToBounds="True">
				<Grid RowDefinitions="Auto,3*,Auto,2*">
					<!-- HEADER -->
					<Border Grid.Row="0" Padding="12,10" BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<Border Grid.Column="0" Cursor="Hand" Margin="0,0,6,0" VerticalAlignment="Center"
							        PointerPressed="OnBrowserCollapsePressed">
								<Panel>
									<iconPacks:PackIconCodicons Kind="ChevronDown" Width="10" Height="10" Foreground="#555570"
									                            IsVisible="{Binding IsBrowserExpanded}"/>
									<iconPacks:PackIconCodicons Kind="ChevronRight" Width="10" Height="10" Foreground="#555570"
									                            IsVisible="{Binding !IsBrowserExpanded}"/>
								</Panel>
							</Border>
							<StackPanel Grid.Column="1" Spacing="2" Cursor="Hand"
							            PointerPressed="OnBrowserCollapsePressed">
								<TextBlock Text="{Binding Loc[Browser]}" Classes="SectionHeader"/>
								<TextBlock Foreground="#555570" FontSize="10" Text="{Binding Loc[FilesAndDirectories]}"/>
							</StackPanel>
							<Button Grid.Column="2" Classes="AccentBtn" Command="{Binding OpenFileCommand}" Padding="10,5">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<iconPacks:PackIconCodicons Kind="Add" Width="14" Height="14"/>
									<TextBlock Text="{Binding Loc[Add]}" FontSize="11"/>
								</StackPanel>
							</Button>
						</Grid>
					</Border>

					<!-- DIRECTORY TREE (collapsible) -->
					<Panel Grid.Row="1" IsVisible="{Binding IsBrowserExpanded}">
					<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,4"
                                  IsVisible="{Binding HasDirectoryLoaded}">
						<ItemsControl ItemsSource="{Binding DirectoryTree}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:FileTreeNodeViewModel">
									<StackPanel>
										<Border Margin="0,1" CornerRadius="4" Padding="6,5" Cursor="Hand"
                                                PointerPressed="OnTreeNodePointerPressed">
											<Border.Styles>
												<Style Selector="Border:pointerover">
													<Setter Property="Background" Value="#1C1C30"/>
												</Style>
											</Border.Styles>
											<StackPanel Orientation="Horizontal" Spacing="4">
												<iconPacks:PackIconCodicons Kind="{Binding IconKind}" Width="10" Height="10" Foreground="#555570"
                                                           VerticalAlignment="Center" Margin="0,0,2,0"/>
												<iconPacks:PackIconCodicons Kind="{Binding FolderIconKind}" Width="12" Height="12" Foreground="#6A9FD6"
                                                           VerticalAlignment="Center" Margin="0,0,2,0"
                                                           IsVisible="{Binding IsDirectory}"/>
												<TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#E8E8F0" TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
											</StackPanel>
										</Border>
										<!-- Level 1 children -->
										<ItemsControl ItemsSource="{Binding Children}" Margin="14,0,0,0"
                                                      IsVisible="{Binding IsExpanded}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="vm:FileTreeNodeViewModel">
													<StackPanel>
														<Border Margin="0,1" CornerRadius="4" Padding="6,4" Cursor="Hand"
                                                                PointerPressed="OnTreeNodePointerPressed">
															<Border.Styles>
																<Style Selector="Border:pointerover">
																	<Setter Property="Background" Value="#1C1C30"/>
																</Style>
															</Border.Styles>
															<StackPanel Orientation="Horizontal" Spacing="4">
																<iconPacks:PackIconCodicons Kind="{Binding IconKind}" Width="10" Height="10"
                                                                           Foreground="#555570" VerticalAlignment="Center" Margin="0,0,2,0"/>
																<iconPacks:PackIconCodicons Kind="{Binding FolderIconKind}" Width="12" Height="12" Foreground="#6A9FD6"
                                                                           VerticalAlignment="Center" Margin="0,0,2,0"
                                                                           IsVisible="{Binding IsDirectory}"/>
																<TextBlock Text="{Binding Name}" FontSize="11"
                                                                           Foreground="{Binding IsDirectory, Converter={StaticResource BoolToWhite}}"
                                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
															</StackPanel>
														</Border>
														<!-- Level 2 children -->
														<ItemsControl ItemsSource="{Binding Children}" Margin="14,0,0,0"
                                                                      IsVisible="{Binding IsExpanded}">
															<ItemsControl.ItemTemplate>
																<DataTemplate x:DataType="vm:FileTreeNodeViewModel">
																	<Border Margin="0,1" CornerRadius="4" Padding="6,4" Cursor="Hand"
                                                                            PointerPressed="OnTreeNodePointerPressed">
																		<Border.Styles>
																			<Style Selector="Border:pointerover">
																				<Setter Property="Background" Value="#1C1C30"/>
																			</Style>
																		</Border.Styles>
																		<StackPanel Orientation="Horizontal" Spacing="4">
																			<iconPacks:PackIconCodicons Kind="{Binding IconKind}" Width="10" Height="10"
                                                                                       Foreground="#555570" VerticalAlignment="Center" Margin="0,0,2,0"/>
																			<iconPacks:PackIconCodicons Kind="{Binding FolderIconKind}" Width="12" Height="12" Foreground="#6A9FD6"
                                                                                       VerticalAlignment="Center" Margin="0,0,2,0"
                                                                                       IsVisible="{Binding IsDirectory}"/>
																			<TextBlock Text="{Binding Name}" FontSize="11"
                                                                                       Foreground="#8888A8"
                                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
																		</StackPanel>
																	</Border>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</StackPanel>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>

					<!-- NO DIRECTORY PLACEHOLDER -->
					<Border IsVisible="{Binding !HasDirectoryLoaded}" Padding="12">
						<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
							<iconPacks:PackIconCodicons Kind="Folder" Width="28" Height="28" HorizontalAlignment="Center" Opacity="0.3"/>
							<TextBlock Text="{Binding Loc[NoDirectoryLoaded]}" Foreground="#444460" FontSize="11"
                                       HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[UseOpenDirectory]}" Foreground="#333350" FontSize="10"
                                       HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					</Panel>

					<!-- SPLITTER between directory tree and open files -->
					<GridSplitter Grid.Row="2" Height="8"
					              HorizontalAlignment="Stretch"
					              ResizeDirection="Rows"
					              Background="Transparent"
					              Cursor="SizeNorthSouth"
					              IsVisible="{Binding HasMultipleFiles}">
						<GridSplitter.Template>
							<ControlTemplate>
								<Border Background="#1A1A2A" BorderBrush="#2A2A3A"
								        BorderThickness="0,1" Height="8" Cursor="SizeNorthSouth">
									<TextBlock Text="···" FontSize="10" Foreground="#4A4A6A"
									    HorizontalAlignment="Center" VerticalAlignment="Center"
									    Margin="0,-4,0,0"/>
								</Border>
							</ControlTemplate>
						</GridSplitter.Template>
					</GridSplitter>

				<!-- OPEN FILES SECTION (only when multiple files) -->
					<DockPanel Grid.Row="3" IsVisible="{Binding HasMultipleFiles}">
					<Border DockPanel.Dock="Top" Padding="12,8">
						<TextBlock Text="{Binding Loc[OpenFilesPanel]}" Classes="SectionHeader" Margin="0"/>
					</Border>
					<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,0,6,4">
						<ItemsControl ItemsSource="{Binding OpenFiles}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:DicomFileViewModel">
									<Border Margin="0,1" CornerRadius="6" Padding="8,6" Cursor="Hand"
                                            Background="{Binding IsActive, Converter={StaticResource BoolToAccent}}"
                                            PointerPressed="OnFileListPointerPressed">
										<Border.Styles>
											<Style Selector="Border:pointerover">
												<Setter Property="Background" Value="#1C1C30"/>
											</Style>
										</Border.Styles>
										<Grid ColumnDefinitions="*,Auto">
											<StackPanel Grid.Column="0" Spacing="2">
												<TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="Medium"
                                                           Foreground="#E8E8F0" TextTrimming="CharacterEllipsis"/>
												<StackPanel Orientation="Horizontal" Spacing="4">
													<Border Background="#1C1C28" CornerRadius="3" Padding="4,1">
														<TextBlock Text="{Binding Modality}" FontSize="9" Foreground="#4A9EFF"/>
													</Border>
													<Border Background="#1C1C28" CornerRadius="3" Padding="4,1">
														<TextBlock Text="{Binding TotalFrames, StringFormat={}{0} fr}" FontSize="9" Foreground="#8888A8"/>
													</Border>
												</StackPanel>
											</StackPanel>
											<Button Grid.Column="1" Classes="DangerBtn"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseFileCommand}"
                                                    CommandParameter="{Binding}" VerticalAlignment="Center">
												<iconPacks:PackIconCodicons Kind="Close" Width="10" Height="10"/>
											</Button>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
					</DockPanel>
				</Grid>
			</Border>

		</Grid>

		<!-- ROW 3: FILMSTRIP COLLAPSE HANDLE -->
		<Border Grid.Row="3" Height="16" Background="#0A0A12"
                BorderBrush="#2A2A3A" BorderThickness="0,1,0,0"
                Cursor="Hand"
                ToolTip.Tip="{Binding Loc[Tip_ToggleFilmstrip]}"
                PointerPressed="OnFilmstripHandlePressed">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
				<TextBlock FontSize="9" Foreground="#444460" Text="{Binding Loc[Filmstrip]}"/>
				<Panel>
					<iconPacks:PackIconCodicons Kind="ChevronDown" Width="9" Height="9" Foreground="#555570"
					                            IsVisible="{Binding ShowMiniFrames}"/>
					<iconPacks:PackIconCodicons Kind="ChevronUp" Width="9" Height="9" Foreground="#555570"
					                            IsVisible="{Binding !ShowMiniFrames}"/>
				</Panel>
			</StackPanel>
		</Border>

		<!-- ROW 4: FILMSTRIP CONTENT -->
		<Border Grid.Row="4" Background="#0A0A12" Height="110" IsVisible="{Binding ShowMiniFrames}">
			<Grid ColumnDefinitions="Auto,*,Auto">
				<Button Grid.Column="0" Classes="IconBtn" Command="{Binding PreviousFrameCommand}"
                        VerticalAlignment="Center" Margin="4,0">
					<iconPacks:PackIconCodicons Kind="ChevronLeft" Width="16" Height="16"/>
				</Button>
				<Grid Grid.Column="1">
					<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNull}}">
						<iconPacks:PackIconCodicons Kind="FolderOpened" Width="16" Height="16" VerticalAlignment="Center" Opacity="0.4"/>
						<TextBlock Text="{Binding Loc[NoFileOpenFrames]}"
                                   Foreground="#444460" FontSize="11" VerticalAlignment="Center"/>
					</StackPanel>
					<ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  x:Name="FilmstripScroller"
                                  IsVisible="{Binding ActiveFile, Converter={x:Static ObjectConverters.IsNotNull}}">
						<ItemsControl ItemsSource="{Binding Thumbnails}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Horizontal" Margin="4,6"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:ThumbnailViewModel">
									<Border Margin="3,0" CornerRadius="4" BorderThickness="2" Cursor="Hand"
                                            Opacity="{Binding Opacity}"
                                            PointerPressed="OnThumbnailPointerPressed">
										<Border.BorderBrush>
											<SolidColorBrush Color="{Binding IsCurrentFrame, Converter={StaticResource BoolToColor}}"/>
										</Border.BorderBrush>
										<Grid Width="74" Height="74">
											<Border Background="#1C1C28" CornerRadius="2">
												<iconPacks:PackIconCodicons Kind="FileMedia" Width="20" Height="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="#333355"
                                                           IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
											</Border>
											<Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                   IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
											<Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                                    Background="#99000000" Padding="0,1" CornerRadius="0,0,2,2">
												<TextBlock Text="{Binding Label}" FontSize="9"
                                                           HorizontalAlignment="Center" Foreground="#AAAACC"/>
											</Border>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
				<Button Grid.Column="2" Classes="IconBtn" Command="{Binding NextFrameCommand}"
                        VerticalAlignment="Center" Margin="4,0">
					<iconPacks:PackIconCodicons Kind="ChevronRight" Width="16" Height="16"/>
				</Button>
			</Grid>
		</Border>

		<!-- ROW 5: ERROR STATUS BAR -->
		<Border Grid.Row="5" Background="#0D0D14" BorderBrush="#2A2A3A" BorderThickness="0,1,0,0"
		        Height="24" IsVisible="{Binding HasStatusError}" Cursor="Hand"
		        x:Name="StatusBar">
			<Grid ColumnDefinitions="Auto,*,Auto" Margin="8,0">
				<iconPacks:PackIconCodicons Grid.Column="0" Kind="Warning" Width="12" Height="12"
				           Foreground="#FFB432" VerticalAlignment="Center" Margin="0,0,6,0"/>
				<TextBlock Grid.Column="1" Text="{Binding ErrorStatusMessage}"
				           Foreground="#C8C8D8" FontSize="10" VerticalAlignment="Center"
				           TextTrimming="CharacterEllipsis"
				           FontFamily="Consolas,Courier New,monospace"/>
				<Button Grid.Column="2" Classes="IconBtn" Padding="4,2"
				        Command="{Binding DismissStatusCommand}" ToolTip.Tip="{Binding Loc[Tip_Dismiss]}">
					<iconPacks:PackIconCodicons Kind="Close" Width="10" Height="10"/>
				</Button>
			</Grid>
		</Border>

		<!-- ROW 6: PLAYBACK BAR -->
		<Border Grid.Row="6" Background="#111118" BorderBrush="#2A2A3A" BorderThickness="0,1,0,0"
                Padding="12,0" Height="56">
			<Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Stretch">

				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<Button Classes="IconBtn" VerticalAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding FirstFrameCommand}" ToolTip.Tip="{Binding Loc[Tip_FirstFrame]}">
						<iconPacks:PackIconCodicons Kind="TriangleLeft" Width="14" Height="14" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn" VerticalAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding PreviousFrameCommand}" ToolTip.Tip="{Binding Loc[Tip_PreviousFrame]}">
						<iconPacks:PackIconCodicons Kind="ChevronLeft" Width="14" Height="14" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="AccentBtn" Command="{Binding TogglePlayCommand}"
                            Width="36" Height="30" Padding="0"
                            VerticalAlignment="Center" VerticalContentAlignment="Center"
                            ToolTip.Tip="{Binding Loc[Tip_PlayPause]}">
						<Panel HorizontalAlignment="Center" VerticalAlignment="Center">
							<iconPacks:PackIconCodicons Kind="DebugPause" Width="14" Height="14" IsVisible="{Binding IsPlaying}"/>
							<iconPacks:PackIconCodicons Kind="Play" Width="14" Height="14" IsVisible="{Binding !IsPlaying}"/>
						</Panel>
					</Button>
					<Button Classes="IconBtn" VerticalAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding NextFrameCommand}" ToolTip.Tip="{Binding Loc[Tip_NextFrame]}">
						<iconPacks:PackIconCodicons Kind="ChevronRight" Width="14" Height="14" VerticalAlignment="Center"/>
					</Button>
					<Button Classes="IconBtn" VerticalAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding LastFrameCommand}" ToolTip.Tip="{Binding Loc[Tip_LastFrame]}">
						<iconPacks:PackIconCodicons Kind="TriangleRight" Width="14" Height="14" VerticalAlignment="Center"/>
					</Button>
					<ToggleButton IsChecked="{Binding LoopPlayback}" Padding="6,0"
                                  Width="30" Height="30"
                                  Background="Transparent" BorderThickness="0" Cursor="Hand"
                                  VerticalAlignment="Center" VerticalContentAlignment="Center"
                                  ToolTip.Tip="{Binding Loc[Tip_LoopPlayback]}">
						<iconPacks:PackIconCodicons Kind="Refresh" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{Binding LoopPlayback, Converter={StaticResource BoolToWhite}}"/>
					</ToggleButton>
				</StackPanel>

				<Grid Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
					<Grid ColumnDefinitions="*,Auto">
						<Slider Name="FrameSlider" Grid.Column="0" Minimum="0" Maximum="{Binding TotalFrames}"
                                Value="{Binding CurrentFrameIndex}"
                                VerticalAlignment="Center"
                                IsSnapToTickEnabled="True" TickFrequency="1"/>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3"
                                    VerticalAlignment="Center" Margin="10,0,0,0">
							<TextBlock Foreground="#E8E8F0" FontSize="11" Text="{Binding CurrentFrameDisplay}"/>
							<TextBlock Foreground="#555570" FontSize="11" Text="/"/>
							<TextBlock Foreground="#8888A8" FontSize="11" Text="{Binding TotalFrames}"/>
						</StackPanel>
					</Grid>
				</Grid>

				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
						<TextBlock Text="{Binding Loc[FPS]}" Foreground="#8888A8" FontSize="11" VerticalAlignment="Center"/>
						<Slider Name="FpsSlider" Minimum="1" Maximum="60" Value="{Binding PlaybackFps}" Width="70" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding PlaybackFps, StringFormat={}{0} fps}"
                                   Foreground="#E8E8F0" FontSize="11" VerticalAlignment="Center" MinWidth="38"/>
					</StackPanel>
					<Rectangle Width="1" Height="20" Fill="#2A2A3A" VerticalAlignment="Center"/>
					<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
						<TextBlock Text="C:" Foreground="#8888A8" FontSize="11" VerticalAlignment="Center"/>
						<Slider Name="WindowCenterSlider" Minimum="0" Maximum="65535" Value="{Binding WindowCenter}" Width="70" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding WindowCenter, StringFormat={}{0:F0}}"
                                   Foreground="#E8E8F0" FontSize="11" VerticalAlignment="Center" MinWidth="34"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
						<TextBlock Text="W:" Foreground="#8888A8" FontSize="11" VerticalAlignment="Center"/>
						<Slider Name="WindowWidthSlider" Minimum="1" Maximum="65535" Value="{Binding WindowWidth}" Width="70" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding WindowWidth, StringFormat={}{0:F0}}"
                                   Foreground="#E8E8F0" FontSize="11" VerticalAlignment="Center" MinWidth="34"/>
					</StackPanel>
				</StackPanel>

			</Grid>
		</Border>

	</Grid>
</Window>
