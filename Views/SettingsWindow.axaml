<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DicomViewer.ViewModels"
        xmlns:svc="using:DicomViewer.Services"
        xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
        x:Class="DicomViewer.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Width="700" Height="500"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        SystemDecorations="BorderOnly"
        Background="#0A0A0E"
        Title="Settings"
        CanResize="False">

	<Window.Styles>
		<!-- Window control buttons -->
		<Style Selector="Button.WinBtn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#8888A8"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Width" Value="46"/>
			<Setter Property="Height" Value="36"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
						<ContentPresenter Content="{TemplateBinding Content}"
						                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
						                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="Button.WinBtnClose:pointerover">
			<Setter Property="Background" Value="#C42B1C"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- Segmented button styling -->
		<Style Selector="Button.SegBtn">
			<Setter Property="Background" Value="#1C1C28"/>
			<Setter Property="Foreground" Value="#8888A8"/>
			<Setter Property="BorderBrush" Value="#2A2A3A"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="14,6"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="MinHeight" Value="30"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="CornerRadius" Value="0"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}"
					        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
					        Padding="{TemplateBinding Padding}">
						<ContentPresenter Content="{TemplateBinding Content}"
						                  HorizontalContentAlignment="Center"
						                  VerticalContentAlignment="Center"/>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="Button.SegBtn:pointerover">
			<Setter Property="Background" Value="#252535"/>
		</Style>
		<Style Selector="Button.SegBtn.Active">
			<Setter Property="Background" Value="#1A3A6A"/>
			<Setter Property="Foreground" Value="#4A9EFF"/>
			<Setter Property="BorderBrush" Value="#4A9EFF"/>
		</Style>
		<Style Selector="Button.SegBtnLeft">
			<Setter Property="CornerRadius" Value="6,0,0,6"/>
		</Style>
		<Style Selector="Button.SegBtnRight">
			<Setter Property="CornerRadius" Value="0,6,6,0"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Button.KeyConflict">
			<Setter Property="BorderBrush" Value="#FF6B6B"/>
			<Setter Property="Background" Value="#2A1A1A"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="36,*,Auto">

		<!-- TITLE BAR -->
		<Border Grid.Row="0" Background="#111118" BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="*,Auto">
				<Border Grid.Column="0" x:Name="TitleBarDragArea" IsHitTestVisible="True">
					<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="14,0">
						<iconPacks:PackIconCodicons Kind="SettingsGear" Width="14" Height="14"
						           Foreground="#8888A8" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding Loc[Settings_Title]}" FontSize="12" Foreground="#E8E8F0" VerticalAlignment="Center"/>
					</StackPanel>
				</Border>
				<Button Grid.Column="1" Classes="WinBtn WinBtnClose" x:Name="CloseBtn">
					<iconPacks:PackIconCodicons Kind="ChromeClose" Width="11" Height="11"/>
				</Button>
			</Grid>
		</Border>

		<!-- MAIN CONTENT -->
		<Grid Grid.Row="1" ColumnDefinitions="200,*">

			<!-- LEFT: Category Navigation -->
			<Border Grid.Column="0" Background="#111118" BorderBrush="#2A2A3A" BorderThickness="0,0,1,0">
				<StackPanel Margin="0,8">
					<Button Classes="SettingsCategoryBtn"
					        Classes.Active="{Binding IsGeneralSelected}"
					        Command="{Binding SelectCategoryCommand}" CommandParameter="General">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<iconPacks:PackIconCodicons Kind="Settings" Width="16" Height="16" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Settings_General]}" FontSize="13" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Classes="SettingsCategoryBtn"
					        Classes.Active="{Binding IsControlsSelected}"
					        Command="{Binding SelectCategoryCommand}" CommandParameter="Controls">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<iconPacks:PackIconCodicons Kind="Record" Width="16" Height="16" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Settings_Controls]}" FontSize="13" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>
			</Border>

			<!-- RIGHT: Content Area -->
			<ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
				<Grid>
					<!-- General Page -->
					<StackPanel IsVisible="{Binding IsGeneralSelected}" Margin="28,24" Spacing="28">

						<!-- Language Setting -->
						<StackPanel Spacing="10">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<iconPacks:PackIconCodicons Kind="Globe" Width="14" Height="14"
								           Foreground="#4A9EFF" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding Loc[Settings_Language]}" Foreground="#555570" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
							</StackPanel>
							<StackPanel Spacing="6">
								<TextBlock Text="{Binding Loc[Settings_DisplayLanguage]}" Foreground="#8888A8" FontSize="11"/>
								<ComboBox ItemsSource="{Binding LanguageOptions}"
								          SelectedIndex="{Binding SelectedLanguageIndex}"
								          MaxWidth="250" HorizontalAlignment="Left"
								          Height="34" FontSize="12"
								          Background="#1C1C28" Foreground="#E8E8F0"
								          BorderBrush="#2A2A3A" BorderThickness="1"
								          CornerRadius="6"/>
							</StackPanel>
						</StackPanel>

						<Rectangle Height="1" Fill="#2A2A3A"/>

						<!-- Default Folder Setting -->
						<StackPanel Spacing="10">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<iconPacks:PackIconCodicons Kind="Folder" Width="14" Height="14"
								           Foreground="#4A9EFF" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding Loc[Settings_DefaultFolder]}" Foreground="#555570" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
							</StackPanel>
							<StackPanel Spacing="6">
								<TextBlock Text="{Binding Loc[Settings_StartupDirectory]}" Foreground="#8888A8" FontSize="11"/>
								<Grid ColumnDefinitions="*,Auto,Auto" Height="34">
									<Border Grid.Column="0" Background="#1C1C28" CornerRadius="6" Padding="12,0"
									        BorderBrush="#2A2A3A" BorderThickness="1" VerticalAlignment="Stretch">
										<TextBlock Text="{Binding DefaultDirectory}" Foreground="#E8E8F0" FontSize="12"
										           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
										           IsVisible="{Binding DefaultDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
									</Border>
									<TextBlock Grid.Column="0" Text="{Binding Loc[Settings_NotSet]}" Foreground="#444460" FontSize="12"
									           VerticalAlignment="Center" Margin="12,0"
									           IsVisible="{Binding DefaultDirectory, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
									<Button Grid.Column="1" Classes="AccentBtn" Command="{Binding BrowseDefaultDirectoryCommand}"
									        Padding="12,0" Height="34" Margin="8,0,0,0">
										<StackPanel Orientation="Horizontal" Spacing="6">
											<iconPacks:PackIconCodicons Kind="FolderOpened" Width="12" Height="12" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Settings_Browse]}" FontSize="11" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button Grid.Column="2" Classes="DangerBtn" Command="{Binding ClearDefaultDirectoryCommand}"
									        Width="34" Height="34" Margin="4,0,0,0"
									        IsVisible="{Binding DefaultDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
										<iconPacks:PackIconCodicons Kind="Close" Width="11" Height="11"
										           HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Button>
								</Grid>
								<TextBlock Text="{Binding Loc[Settings_DirectoryAutoLoad]}"
								           Foreground="#444460" FontSize="10" TextWrapping="Wrap"/>
							</StackPanel>
						</StackPanel>

						<Rectangle Height="1" Fill="#2A2A3A"/>

						<!-- Show Tooltips Setting -->
						<StackPanel Spacing="10">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<iconPacks:PackIconCodicons Kind="Info" Width="14" Height="14"
								           Foreground="#4A9EFF" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding Loc[Settings_Interface]}" Foreground="#555570" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
							</StackPanel>
							<Grid ColumnDefinitions="*,Auto" Height="34">
								<StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
									<TextBlock Text="{Binding Loc[Settings_ShowTooltips]}" Foreground="#E8E8F0" FontSize="12"/>
									<TextBlock Text="{Binding Loc[Settings_ShowTooltipsDesc]}"
									           Foreground="#444460" FontSize="10" TextWrapping="Wrap"/>
								</StackPanel>
								<ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowTooltips}"
								              OnContent="" OffContent=""
								              VerticalAlignment="Center"/>
							</Grid>

							<Grid ColumnDefinitions="*,Auto" Height="34">
								<StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
									<TextBlock Text="{Binding Loc[Settings_ShowNotifications]}" Foreground="#E8E8F0" FontSize="12"/>
									<TextBlock Text="{Binding Loc[Settings_ShowNotificationsDesc]}"
									           Foreground="#444460" FontSize="10" TextWrapping="Wrap"/>
								</StackPanel>
								<ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowNotifications}"
								              OnContent="" OffContent=""
								              VerticalAlignment="Center"/>
							</Grid>

							<!-- Startup Window Mode -->
							<Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
								<StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
									<TextBlock Text="{Binding Loc[Settings_WindowMode]}" Foreground="#E8E8F0" FontSize="12"/>
									<TextBlock Text="{Binding Loc[Settings_WindowModeDesc]}"
									           Foreground="#444460" FontSize="10" TextWrapping="Wrap"/>
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
									<Button Classes="SegBtn SegBtnLeft"
									        Classes.Active="{Binding IsWindowedMode}"
									        Command="{Binding SetWindowModeCommand}" CommandParameter="Windowed">
										<TextBlock Text="{Binding Loc[Settings_Windowed]}"/>
									</Button>
									<Button Classes="SegBtn"
									        Classes.Active="{Binding IsMaximizedMode}"
									        Command="{Binding SetWindowModeCommand}" CommandParameter="Maximized">
										<TextBlock Text="{Binding Loc[Settings_Maximized]}"/>
									</Button>
									<Button Classes="SegBtn SegBtnRight"
									        Classes.Active="{Binding IsFullscreenMode}"
									        Command="{Binding SetWindowModeCommand}" CommandParameter="Fullscreen">
										<TextBlock Text="{Binding Loc[Settings_Fullscreen]}"/>
									</Button>
								</StackPanel>
							</Grid>
						</StackPanel>

					</StackPanel>

					<!-- Controls Page -->
					<StackPanel IsVisible="{Binding IsControlsSelected}" Margin="28,24" Spacing="20">

						<!-- Header + Reset -->
						<Grid ColumnDefinitions="*,Auto">
							<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
								<iconPacks:PackIconCodicons Kind="Record" Width="14" Height="14"
								           Foreground="#4A9EFF" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding Loc[Controls_KeyboardShortcuts]}" Foreground="#555570" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
							</StackPanel>
							<Button Grid.Column="1" Classes="DangerBtn" Command="{Binding ResetKeyBindingsCommand}"
							        Padding="10,4" VerticalAlignment="Center">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<iconPacks:PackIconCodicons Kind="DebugRestart" Width="11" Height="11" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Loc[Controls_ResetAll]}" FontSize="10" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>
						</Grid>

						<TextBlock Text="{Binding Loc[Controls_RebindHint]}"
						           Foreground="#444460" FontSize="10" TextWrapping="Wrap" Margin="0,-12,0,0"/>

						<!-- Playback Section -->
						<StackPanel Spacing="4">
							<TextBlock Text="{Binding Loc[Controls_Playback]}" Foreground="#8888A8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<ItemsControl ItemsSource="{Binding PlaybackBindings}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:KeyBindingRowViewModel">
										<Grid ColumnDefinitions="*,Auto" Margin="0,1" Height="30">
											<TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#E8E8F0" FontSize="11"
											           VerticalAlignment="Center"/>
											<Button Grid.Column="1" Classes="SegBtn" Padding="10,4" MinWidth="90"
											        Classes.KeyConflict="{Binding HasConflict}"
											        ToolTip.Tip="{Binding ConflictMessage}"
											        x:Name="KeyBtn" Tag="{Binding}">
												<Panel>
													<TextBlock Text="{Binding DisplayString}" FontSize="11"
													           IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
													<TextBlock Text="{Binding Loc[Controls_PressKey]}" FontSize="11" Foreground="#4A9EFF" FontStyle="Italic"
													           IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
												</Panel>
											</Button>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>

						<Rectangle Height="1" Fill="#2A2A3A"/>

						<!-- View Section -->
						<StackPanel Spacing="4">
							<TextBlock Text="{Binding Loc[Controls_View]}" Foreground="#8888A8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<ItemsControl ItemsSource="{Binding ViewBindings}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:KeyBindingRowViewModel">
										<Grid ColumnDefinitions="*,Auto" Margin="0,1" Height="30">
											<TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#E8E8F0" FontSize="11"
											           VerticalAlignment="Center"/>
											<Button Grid.Column="1" Classes="SegBtn" Padding="10,4" MinWidth="90"
											        Classes.KeyConflict="{Binding HasConflict}"
											        ToolTip.Tip="{Binding ConflictMessage}"
											        Tag="{Binding}">
												<Panel>
													<TextBlock Text="{Binding DisplayString}" FontSize="11"
													           IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
													<TextBlock Text="{Binding Loc[Controls_PressKey]}" FontSize="11" Foreground="#4A9EFF" FontStyle="Italic"
													           IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
												</Panel>
											</Button>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>

						<Rectangle Height="1" Fill="#2A2A3A"/>

						<!-- Tools Section -->
						<StackPanel Spacing="4">
							<TextBlock Text="{Binding Loc[Controls_AnnotationTools]}" Foreground="#8888A8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<ItemsControl ItemsSource="{Binding ToolBindings}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:KeyBindingRowViewModel">
										<Grid ColumnDefinitions="*,Auto" Margin="0,1" Height="30">
											<TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#E8E8F0" FontSize="11"
											           VerticalAlignment="Center"/>
											<Button Grid.Column="1" Classes="SegBtn" Padding="10,4" MinWidth="90"
											        Classes.KeyConflict="{Binding HasConflict}"
											        ToolTip.Tip="{Binding ConflictMessage}"
											        Tag="{Binding}">
												<Panel>
													<TextBlock Text="{Binding DisplayString}" FontSize="11"
													           IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
													<TextBlock Text="{Binding Loc[Controls_PressKey]}" FontSize="11" Foreground="#4A9EFF" FontStyle="Italic"
													           IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
												</Panel>
											</Button>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>

						<Rectangle Height="1" Fill="#2A2A3A"/>

						<!-- File & Edit Section -->
						<StackPanel Spacing="4">
							<TextBlock Text="{Binding Loc[Controls_File]}" Foreground="#8888A8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<ItemsControl ItemsSource="{Binding FileBindings}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:KeyBindingRowViewModel">
										<Grid ColumnDefinitions="*,Auto" Margin="0,1" Height="30">
											<TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#E8E8F0" FontSize="11"
											           VerticalAlignment="Center"/>
											<Button Grid.Column="1" Classes="SegBtn" Padding="10,4" MinWidth="90"
											        Classes.KeyConflict="{Binding HasConflict}"
											        ToolTip.Tip="{Binding ConflictMessage}"
											        Tag="{Binding}">
												<Panel>
													<TextBlock Text="{Binding DisplayString}" FontSize="11"
													           IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
													<TextBlock Text="{Binding Loc[Controls_PressKey]}" FontSize="11" Foreground="#4A9EFF" FontStyle="Italic"
													           IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
												</Panel>
											</Button>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>

						<Rectangle Height="1" Fill="#2A2A3A"/>

						<StackPanel Spacing="4">
							<TextBlock Text="{Binding Loc[Controls_Edit]}" Foreground="#8888A8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<ItemsControl ItemsSource="{Binding EditBindings}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:KeyBindingRowViewModel">
										<Grid ColumnDefinitions="*,Auto" Margin="0,1" Height="30">
											<TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#E8E8F0" FontSize="11"
											           VerticalAlignment="Center"/>
											<Button Grid.Column="1" Classes="SegBtn" Padding="10,4" MinWidth="90"
											        Classes.KeyConflict="{Binding HasConflict}"
											        ToolTip.Tip="{Binding ConflictMessage}"
											        Tag="{Binding}">
												<Panel>
													<TextBlock Text="{Binding DisplayString}" FontSize="11"
													           IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
													<TextBlock Text="{Binding Loc[Controls_PressKey]}" FontSize="11" Foreground="#4A9EFF" FontStyle="Italic"
													           IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
												</Panel>
											</Button>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>

					</StackPanel>
				</Grid>
			</ScrollViewer>

		</Grid>

		<!-- FOOTER: Save & Close -->
		<Border Grid.Row="2" Background="#111118" BorderBrush="#2A2A3A" BorderThickness="0,1,0,0" Padding="16,10">
			<Grid ColumnDefinitions="Auto,*,Auto,Auto">
				<!-- Save confirmation -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
				            IsVisible="{Binding ShowSaveConfirmation}" VerticalAlignment="Center">
					<iconPacks:PackIconCodicons Kind="Check" Width="14" Height="14" Foreground="#4ADE80" VerticalAlignment="Center"/>
					<TextBlock Text="{Binding Loc[Settings_Saved]}" FontSize="12" Foreground="#4ADE80" VerticalAlignment="Center"/>
				</StackPanel>
				<Button Grid.Column="2" Classes="SegBtn" Command="{Binding SaveCommand}"
				        IsEnabled="{Binding HasUnsavedChanges}" Padding="20,8" Margin="0,0,8,0">
					<StackPanel Orientation="Horizontal" Spacing="6" Opacity="1">
						<StackPanel.Styles>
							<Style Selector="Button:disabled StackPanel">
								<Setter Property="Opacity" Value="0.4"/>
							</Style>
						</StackPanel.Styles>
						<iconPacks:PackIconCodicons Kind="Save" Width="14" Height="14" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding Loc[Settings_Save]}" FontSize="12" VerticalAlignment="Center"/>
					</StackPanel>
				</Button>
				<Button Grid.Column="3" Classes="AccentBtn" Command="{Binding CloseCommand}" Padding="20,8">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<iconPacks:PackIconCodicons Kind="ChromeClose" Width="14" Height="14" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding Loc[Settings_SaveClose]}" FontSize="12" VerticalAlignment="Center"/>
					</StackPanel>
				</Button>
			</Grid>
		</Border>
	</Grid>

</Window>
